{
  "name": "video-browser",
  "version": "1.0.0",
  "description": "Local video browser for external hard drives",
  "scripts": {
    "dev": "node scripts/start.js",
    "scan": "node scanner/scan.js",
    "frontend": "cd frontend && npm run dev",
    "server": "node server/index.js",
    "install:all": "npm install && cd frontend && npm install",
    "test": "jest --runInBand --detectOpenHandles",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "keywords": [
    "video",
    "browser",
    "local"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "jest": "^29.7.0",
    "supertest": "^6.3.4",
    "typescript": "^5.3.3"
  }
}
